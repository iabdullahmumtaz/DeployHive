{
  "name": "deployhive",
  "version": "1.0.0",
  "description": "DevOps deployment panel — deploy from Git with Docker support",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "npm run dev --prefix src/client",
    "build": "npm run build --prefix src/client",
    "start": "tsx src/server/index.ts",
    "install:all": "npm install && npm install --prefix src/client"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "simple-git": "^3.27.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
